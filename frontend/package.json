{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve --host 0.0.0.0 --port 4200 --watch --poll=2000",
    "start:local": "ng serve --host 0.0.0.0 --port 4201 --watch --poll=2000",
    "lint": "ng lint",
    "clean:reports": "rimraf ./vitest || rmdir /s /q vitest",
    "test": "npm run clean:reports && ng test --watch=false --coverage",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:ci": "cypress run --reporter junit --reporter-options \"mochaFile=cypress/results/junit-[hash].xml,toConsole=true\"",
    "e2e": "start-server-and-test start:local http://localhost:4201 cy:run",
    "e2e:ci": "start-server-and-test start:local http://localhost:4201 cy:run:ci",
    "precommit": "npm run lint && npm run test && npm run build",
    "build": "ng build"
  },
  "prettier": {
    "printWidth": 500,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.0",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/localize": "21.1.4",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "@angular/platform-server": "^21.1.4",
    "@angular/ssr": "^21.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "angular-eslint": "21.2.0",
    "eslint": "^9.39.2",
    "jsdom": "^27.1.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "start-server-and-test": "^2.1.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.50.1",
    "vitest": "^4.0.8",
    "cypress": "^15.3.0"
  }
}
